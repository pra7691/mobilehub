generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  super_admin
  admin
  moderator
}

enum UserStatus {
  active
  inactive
  suspended
  disabled
}

enum TaskStatus {
  active
  inactive
  draft
}

enum CollectionType {
  VIDEO
  IMAGE
  AUDIO
}

enum CameraPreference {
  REAR
  FRONT
  ANY
}

enum LensPreference {
  ULTRA_WIDE
  STANDARD
  ANY
}

enum OrientationRequirement {
  PORTRAIT
  LANDSCAPE
  ANY
}

enum SubmissionStatus {
  DRAFT
  UPLOADING
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESUBMISSION_REQUIRED
  UPLOAD_FAILED
}

enum MediaType {
  VIDEO
  IMAGE
  AUDIO
  THUMBNAIL
}

enum MediaUploadStatus {
  PENDING
  UPLOADING
  UPLOADED
  FAILED
}

enum TransactionType {
  CREDIT
  DEBIT
  ADJUSTMENT
  PAYOUT_HOLD
  PAYOUT_COMPLETED
  PAYOUT_REVERSED
}

enum TransactionSourceType {
  SUBMISSION
  ADMIN_ADJUSTMENT
  PAYOUT
  REFERRAL_REWARD
}

enum ReferralStatus {
  REGISTERED
  QUALIFIED
  REWARDED
  CANCELLED
}

enum TransactionStatus {
  COMPLETED
  PENDING
  REVERSED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
  CANCELLED
}

enum StorageProviderType {
  REPLIT
  AWS_S3
  CLOUDFLARE_R2
  DIGITALOCEAN_SPACES
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  role         AdminRole @default(admin)
  isActive     Boolean   @default(true)
  tokenVersion Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  auditLogs AdminAuditLog[]

  @@map("admin_users")
}

model User {
  id                String     @id @default(cuid())
  phoneNumber       String     @unique
  name              String?
  preferredLanguage String     @default("en")
  status            UserStatus @default(active)
  referralCode      String?    @unique
  referredByUserId  String?
  referralAppliedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  otpSessions        OtpSession[]
  submissions        Submission[]
  wallet             Wallet?
  walletTransactions WalletTransaction[]
  deviceTokens       DeviceToken[]
  notifications      Notification[]
  mobileErrorLogs    MobileErrorLog[]
  refreshTokens      RefreshToken[]
  uploadSessions     UploadSession[]
  paymentMethods     UserPaymentMethod[]
  payoutRequests     PayoutRequest[]
  referredBy         User?               @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referredUsers      User[]              @relation("UserReferrals")
  referralsMade      Referral[]          @relation("ReferrerUser")
  referralReceived   Referral?           @relation("ReferredUser")

  @@map("users")
}

model Referral {
  id                         String         @id @default(cuid())
  referrerUserId             String
  referredUserId             String         @unique
  referralCode               String
  status                     ReferralStatus @default(REGISTERED)
  registeredAt               DateTime       @default(now())
  qualifiedAt                DateTime?
  rewardedAt                 DateTime?
  rewardAmount               Decimal?       @db.Decimal(10, 2)
  rewardWalletTransactionId  String?        @unique
  firstQualifiedSubmissionId String?
  note                       String?
  createdBySystem            Boolean        @default(true)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  referrer User @relation("ReferrerUser", fields: [referrerUserId], references: [id])
  referred User @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@index([referrerUserId])
  @@index([status])
  @@map("referrals")
}

model ReferralSetting {
  id            String   @id @default(cuid())
  isEnabled     Boolean  @default(false)
  rewardAmount  Decimal  @default(0) @db.Decimal(10, 2)
  message       String?
  updatedAt     DateTime @updatedAt

  @@map("referral_settings")
}

model OtpSetting {
  id               String   @id @default(cuid())
  otpLength        Int      @default(6)
  otpExpirySeconds Int      @default(300)
  maxAttempts      Int      @default(3)
  cooldownSeconds  Int      @default(60)
  isTestMode          Boolean  @default(false)
  testOtp             String?
  allowedPhoneNumbers String?
  updatedAt           DateTime @updatedAt

  @@map("otp_settings")
}

model OtpSession {
  id          String   @id @default(cuid())
  userId      String?
  phoneNumber String
  otp         String
  attempts    Int      @default(0)
  expiresAt   DateTime
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([phoneNumber, expiresAt])
  @@map("otp_sessions")
}

model Category {
  id            String    @id @default(cuid())
  name          String
  description   String?
  nameEn        String?
  nameHi        String?
  descriptionEn String?
  descriptionHi String?
  icon          String?
  coverImageUrl String?
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  subcategories Subcategory[]
  tasks         Task[]
  submissions   Submission[]

  @@map("categories")
}

model Subcategory {
  id            String    @id @default(cuid())
  name          String
  description   String?
  nameEn        String?
  nameHi        String?
  descriptionEn String?
  descriptionHi String?
  categoryId    String
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  category    Category     @relation(fields: [categoryId], references: [id])
  tasks       Task[]
  submissions Submission[]

  @@map("subcategories")
}

model Task {
  id                       String                 @id @default(cuid())
  title                    String
  description              String?
  detailedInstructions     String?
  dos                      String[]
  donts                    String[]
  titleEn                  String?
  titleHi                  String?
  shortDescriptionEn       String?
  shortDescriptionHi       String?
  detailedInstructionsEn   String?
  detailedInstructionsHi   String?
  dosEn                    String[]
  dosHi                    String[]
  dontsEn                  String[]
  dontsHi                  String[]
  categoryId             String
  subcategoryId          String?
  collectionType         CollectionType         @default(IMAGE)
  paymentAmount          Decimal                @default(0) @db.Decimal(10, 2)
  currency               String                 @default("INR")
  sampleMediaUrl         String?
  minimumDurationSeconds Int?
  maximumDurationSeconds Int?
  minimumImageCount      Int?
  maximumImageCount      Int?
  preferredFps           Float?
  minimumFps             Float?
  preferredCamera        CameraPreference       @default(ANY)
  preferredLens          LensPreference         @default(ANY)
  requiredOrientation    OrientationRequirement @default(ANY)
  audioRequired          Boolean                @default(false)
  pauseAllowed           Boolean                @default(true)
  recordImu              Boolean                @default(false)
  imuRequired            Boolean                @default(false)
  maxSubmissionsPerUser  Int?
  maxTotalSubmissions    Int?
  startDate              DateTime?
  endDate                DateTime?
  displayOrder           Int                    @default(0)
  status                 TaskStatus             @default(draft)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  deletedAt              DateTime?

  category    Category     @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])
  submissions Submission[]

  @@map("tasks")
}

model Submission {
  id                    String           @id @default(cuid())
  userId                String
  taskId                String
  categoryId            String?
  subcategoryId         String?
  collectionType        CollectionType
  status                SubmissionStatus @default(DRAFT)
  submittedAt           DateTime?
  uploadStartedAt       DateTime?
  uploadCompletedAt     DateTime?
  captureStartedAt      DateTime?
  captureEndedAt        DateTime?
  durationSeconds       Int?
  imageCount            Int?
  totalFileSize         BigInt?
  devicePlatform        String?
  deviceModel           String?
  osVersion             String?
  cameraUsed            String?
  lensRequested         String?
  orientation           String?
  captureMetadata       Json?
  taskSnapshot          Json
  paymentAmountSnapshot Decimal          @db.Decimal(10, 2)
  currencySnapshot      String           @default("INR")
  failureReason         String?
  approvedAmount        Decimal?         @db.Decimal(10, 2)
  rejectionReason       String?
  resubmissionReason    String?
  adminNote             String?
  reviewedBy            String?
  reviewedAt            DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  task        Task              @relation(fields: [taskId], references: [id])
  category    Category?         @relation(fields: [categoryId], references: [id])
  subcategory Subcategory?      @relation(fields: [subcategoryId], references: [id])
  media       SubmissionMedia[]

  @@index([userId, status])
  @@index([taskId, status])
  @@index([createdAt])
  @@map("submissions")
}

model SubmissionMedia {
  id              String            @id @default(cuid())
  submissionId    String
  mediaType       MediaType
  storageKey       String
  mediaUrl         String
  storageProfileId String?
  storageProvider  String?
  bucket           String?
  originalFileName String?
  thumbnailUrl     String?
  fileSize        BigInt?
  durationSeconds Int?
  width           Int?
  height          Int?
  mimeType        String
  sortOrder       Int               @default(0)
  uploadStatus    MediaUploadStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  submission     Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  storageProfile StorageProfile? @relation(fields: [storageProfileId], references: [id])

  @@unique([submissionId, sortOrder])
  @@map("submission_media")
}

model Wallet {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  availableBalance         Decimal  @default(0) @db.Decimal(10, 2)
  pendingBalance           Decimal  @default(0) @db.Decimal(10, 2)
  pendingWithdrawalBalance Decimal  @default(0) @db.Decimal(10, 2)
  lifetimeEarnings         Decimal  @default(0) @db.Decimal(10, 2)
  totalWithdrawn           Decimal  @default(0) @db.Decimal(10, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  userId        String
  type          TransactionType
  sourceType    TransactionSourceType
  sourceId      String?
  amount        Decimal               @db.Decimal(10, 2)
  balanceBefore Decimal               @db.Decimal(10, 2)
  balanceAfter  Decimal               @db.Decimal(10, 2)
  note          String?
  status        TransactionStatus     @default(COMPLETED)
  createdAt     DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([sourceType, sourceId])
  @@index([userId, createdAt])
  @@map("wallet_transactions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  adminEmail String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  requestId  String?
  createdAt  DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Faq {
  id           String    @id @default(cuid())
  question     String
  answer       String
  questionEn   String?
  questionHi   String?
  answerEn     String?
  answerHi     String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@map("faqs")
}

model StaticPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  titleEn     String?
  titleHi     String?
  contentEn   String?
  contentHi   String?
  isPublished Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("static_pages")
}

model SupportSettings {
  id               String   @id @default(cuid())
  email            String
  whatsappNumber   String
  phoneNumber      String?
  workingHours     String?
  message          String?
  supportMessageEn String?
  supportMessageHi String?
  updatedAt        DateTime @updatedAt

  @@map("support_settings")
}

model AppSetting {
  key         String   @id
  value       String?
  content     String?
  title       String?
  isPublished Boolean  @default(false)
  version     Int      @default(1)
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

model Notice {
  id        String    @id @default(cuid())
  title     String
  content   String
  titleEn   String?
  titleHi   String?
  contentEn String?
  contentHi String?
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("notices")
}

enum NotificationType {
  SUBMISSION_APPROVED
  SUBMISSION_REJECTED
  RESUBMISSION_REQUIRED
  NEW_TASK
  APP_NOTICE
  PAYOUT_PAID
  PAYOUT_REJECTED
}

enum NotificationEntityType {
  SUBMISSION
  TASK
  NOTICE
  PAYOUT
}

model DeviceToken {
  id                      String   @id @default(cuid())
  userId                  String
  expoPushToken           String
  platform                String
  deviceId                String?
  isActive                Boolean  @default(true)
  lastSeenAt              DateTime @default(now())
  notifySubmissionUpdates Boolean  @default(true)
  notifyNewTasks          Boolean  @default(true)
  notifyAppNotices        Boolean  @default(true)
  notifyPayoutUpdates     Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, expoPushToken])
  @@map("device_tokens")
}

model Notification {
  id                String                  @id @default(cuid())
  userId            String
  title             String
  body              String
  type              NotificationType
  relatedEntityType NotificationEntityType?
  relatedEntityId   String?
  isRead            Boolean                 @default(false)
  sentAt            DateTime?
  deliveryError     String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model MobileErrorLog {
  id             String    @id @default(cuid())
  userId         String?
  errorType      String
  errorCode      String?
  message        String
  stackTrace     String?
  endpoint       String?
  httpMethod     String?
  httpStatus     Int?
  requestId      String?
  platform       String
  deviceModel    String?
  osVersion      String?
  appVersion     String?
  networkState   String?
  collectionType String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([errorType])
  @@map("mobile_error_logs")
}

model UserPaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("UPI")
  upiId       String
  upiIdMasked String
  isDefault   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  payoutRequests PayoutRequest[]

  @@index([userId])
  @@map("user_payment_methods")
}

model PayoutRequest {
  id                            String       @id @default(cuid())
  userId                        String
  paymentMethodId               String
  amount                        Decimal      @db.Decimal(10, 2)
  currency                      String       @default("INR")
  status                        PayoutStatus @default(PENDING)
  requestedAt                   DateTime     @default(now())
  processingStartedAt           DateTime?
  processedAt                   DateTime?
  paidAt                        DateTime?
  rejectedAt                    DateTime?
  cancelledAt                   DateTime?
  processedByAdminId            String?
  rejectionReason               String?
  adminNote                     String?
  payoutReferenceId             String?
  walletHoldTransactionId       String?
  walletCompletionTransactionId String?
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt

  user          User              @relation(fields: [userId], references: [id])
  paymentMethod UserPaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("payout_requests")
}

model Banner {
  id                String    @id @default(cuid())
  imageUrl          String
  mobileImageUrl    String?
  titleEn           String?
  titleHi           String?
  descriptionEn     String?
  descriptionHi     String?
  displayOrder      Int       @default(0)
  isActive          Boolean   @default(true)
  startDate         DateTime?
  endDate           DateTime?
  deletedAt         DateTime?
  createdByAdminId  String?
  updatedByAdminId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([isActive, displayOrder])
  @@index([deletedAt])
  @@map("banners")
}

model AccountDeletionRequest {
  id          String   @id @default(cuid())
  phoneNumber String
  reason      String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@map("account_deletion_requests")
}

model StorageProfile {
  id                   String              @id @default(cuid())
  name                 String
  providerType         StorageProviderType
  bucket               String?
  region               String?
  endpoint             String?
  publicBaseUrl        String?
  keyPrefix            String              @default("tarzi")
  isActive             Boolean             @default(false)
  encryptedCredentials String?
  lastTestedAt         DateTime?
  lastTestResult       String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  media          SubmissionMedia[]
  uploadSessions UploadSession[]

  @@map("storage_profiles")
}

enum UploadSessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ABORTED
  FAILED
}

model UploadSession {
  id               String              @id @default(cuid())
  userId           String
  submissionId     String?
  mediaId          String?             @unique
  storageProfileId String?
  storageProvider  String
  bucket           String
  storageKey       String
  uploadId         String?
  isVirtual        Boolean             @default(false)
  status           UploadSessionStatus @default(PENDING)
  mediaType        String
  mimeType         String
  originalFileName String?
  fileSize         BigInt?
  partSize         Int?
  totalParts       Int?
  uploadedParts    Json                @default("[]")
  expiresAt        DateTime
  completedAt      DateTime?
  abortedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  storageProfile StorageProfile? @relation(fields: [storageProfileId], references: [id])

  @@index([userId, status])
  @@index([submissionId])
  @@index([expiresAt])
  @@map("upload_sessions")
}
