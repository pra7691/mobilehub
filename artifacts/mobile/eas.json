{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mobile-data-hub.replit.app/api"
      }
    },
    "production": {
      "corepack": true,
      "pnpm": "10.26.1",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mobile-data-hub.replit.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
