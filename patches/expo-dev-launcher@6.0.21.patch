+    fun attempt(isRetry: Boolean) {
+      scanner.startScan()
+        .addOnSuccessListener { barcode ->
+          barcode.rawValue?.let { onResult(it) } ?: onError("No QR code data found")
+        }
+        .addOnCanceledListener {
+          if (!isRetry) onError("Scanning cancelled")
+        }
+        .addOnFailureListener { exception ->
+          if (isRetry) {
+            // Second attempt also failed — surface the full diagnostic string.
+            val cls = exception.javaClass.simpleName
+            val msg = exception.message ?: "Unknown error"
+            onError("QR_SCANNER_START_FAILED [$cls]: $msg — GMS module may still be downloading; try again shortly")
+          } else {
+            // First failure: GMS is likely downloading the code-scanner module in the
+            // background. Wait 3 s then retry so the user does not have to tap again.
+            viewModelScope.launch {
+              delay(3_000L)
+              attempt(isRetry = true)
+            }
+          }
+        }
+    }
+    attempt(isRetry = false)
   }
