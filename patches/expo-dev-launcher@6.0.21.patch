+   *   in Application.onCreate() so the module is ready before the user ever opens this menu.
+   */
   fun scanQRCode(context: Context, onResult: (String) -> Unit, onError: (String) -> Unit) {
     val options = GmsBarcodeScannerOptions.Builder()
