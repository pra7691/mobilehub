# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/capto

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign JWT access + refresh tokens (required)
JWT_SECRET=change-me-to-a-long-random-string

# Secret used to sign admin sessions (required)
SESSION_SECRET=change-me-to-another-long-random-string

# ─── Object Storage ────────────────────────────────────────────────────────────
# Replit Object Storage bucket path (required).
# Set this in the Object Storage tool in your Replit workspace.
# Format: /bucket-name
PRIVATE_OBJECT_DIR=/your-bucket-name

# ─── Server ────────────────────────────────────────────────────────────────────
# Port the NestJS API server binds to (defaults to 8080)
PORT=8080

# Node environment — set to "production" in deployed environments
NODE_ENV=development
