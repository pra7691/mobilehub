auto-install-peers=false
strict-peer-dependencies=false
# Hoist expo CLI and React Native Gradle dependencies to workspace root
# so EAS Build can invoke expo from the git root and Gradle can resolve
# react-native packages via `node --print "require.resolve(...)"` calls
# in android/app/build.gradle.
public-hoist-pattern[]=expo
public-hoist-pattern[]=@expo/cli
public-hoist-pattern[]=react-native
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=expo-modules-autolinking
